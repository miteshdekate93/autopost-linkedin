# LinkedIn Post Automation — Environment Variables
# Copy this file to .env for local testing
# NEVER commit your actual .env file — it contains secrets!

# LinkedIn Developer App credentials
# Get from: https://developer.linkedin.com/ → Your App → Auth tab
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 tokens (expires every 60 days — script auto-refreshes)
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_REFRESH_TOKEN=your_refresh_token_here

# Your LinkedIn Person URN
# Get by calling: curl -H "Authorization: Bearer YOUR_TOKEN" https://api.linkedin.com/v2/me
# Format: urn:li:person:XXXXXXXXXXXXXXXX
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here
